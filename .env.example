# All of the following are OPTIONAL. The app works with zero env vars —
# it will use in-memory profile storage, in-memory vector search and a
# deterministic template LLM so you can demo the pipeline without any keys.

# --- LLM + embeddings (OpenAI) --------------------------------------------
# When set, /api/ask uses OpenAI for both embeddings and chat completions.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Local LLM (Ollama) ---------------------------------------------------
# Used as a fallback when OPENAI_API_KEY is not set, if Ollama is reachable.
# Pull a model first, e.g. `ollama pull llama3.2:1b`.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# --- Vector DB (Qdrant) ---------------------------------------------------
# When set, knowledge chunks are stored/retrieved from a Qdrant collection.
# Point at Qdrant Cloud or a self-hosted instance.
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=gym_ai_coach

# --- Profile DB (Supabase) ------------------------------------------------
# When set, user profiles are upserted via Supabase PostgREST.
# Requires a `profiles` table: (id text primary key, data jsonb, updated_at timestamptz)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
