# All of the following are OPTIONAL. The app works with zero env vars —
# it will use in-memory profile storage, in-memory vector search and a
# deterministic template LLM so you can demo the pipeline without any keys.

# --- LLM (OpenAI-compatible: OpenAI, OpenRouter, Groq, Together, ...) -----
# OPENAI_BASE_URL defaults to https://api.openai.com/v1. Point it at any
# OpenAI-compatible provider to use their models.
#
# Examples:
#   OpenAI:     OPENAI_BASE_URL=https://api.openai.com/v1
#               OPENAI_MODEL=gpt-4o-mini
#   OpenRouter: OPENAI_BASE_URL=https://openrouter.ai/api/v1
#               OPENAI_MODEL=anthropic/claude-3.5-sonnet
#   Groq:       OPENAI_BASE_URL=https://api.groq.com/openai/v1
#               OPENAI_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# Optional, only used when OPENAI_BASE_URL points at OpenRouter. Used for
# request attribution in your OpenRouter dashboard.
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Gym AI Coach

# --- Local LLM (Ollama) ---------------------------------------------------
# Used as a fallback when OPENAI_API_KEY is not set, if Ollama is reachable.
# Pull a model first, e.g. `ollama pull llama3.2:1b`.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# --- Vector DB (Qdrant) ---------------------------------------------------
# When set, knowledge chunks are stored/retrieved from a Qdrant collection.
# Point at Qdrant Cloud or a self-hosted instance.
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=gym_ai_coach

# --- Profile DB (Supabase) ------------------------------------------------
# When set, user profiles are upserted via Supabase PostgREST.
# Requires a `profiles` table: (id text primary key, data jsonb, updated_at timestamptz)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
